# =============================================
# LawLens Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# =============================================

# Database (use Neon, Supabase, or Railway Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT Auth
SECRET_KEY=your-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Razorpay Payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Hugging Face (for loading private models)
HUGGINGFACE_TOKEN=your-huggingface-token

# Model identifiers on Hugging Face Hub
CLASSIFICATION_MODEL=Rohit171717/lawlens-classification
SUMMARIZATION_MODEL=Rohit171717/lawlens-summarization

# Gemini / Groq API keys
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173
